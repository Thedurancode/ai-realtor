FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV HOME=/root
ENV PATH="$HOME/.local/bin:$HOME/.nvm/versions/node/v22/bin:$PATH"

# System deps
RUN apt-get update && apt-get install -y \
    curl git wget unzip python3 python3-pip python3-venv \
    build-essential ca-certificates gnupg \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# uv/uvx (Python tool runner)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Directory structure
RUN mkdir -p $HOME/.claude/plugins \
    $HOME/.claude/backups \
    $HOME/Documents/GitHub

# Copy local repo instead of cloning (works with private repos)
COPY . $HOME/Documents/GitHub/ai-realtor

WORKDIR $HOME/Documents/GitHub/ai-realtor

# Full app + ClaudeBot Python deps
RUN pip3 install --break-system-packages -r requirements.txt \
    python-telegram-bot "discord.py"

# Fix MCP config paths for Linux container
RUN python3 -c "import json; f=open('.mcp.json'); cfg=json.load(f); f.close(); \
    [srv.update({'cwd':'/root/Documents/GitHub/ai-realtor'}) for srv in cfg.get('mcpServers',{}).values() if 'cwd' in srv]; \
    [srv.update({'args':[a.replace('/Users/edduran/Documents/GitHub/ai-realtor','/root/Documents/GitHub/ai-realtor') for a in srv['args']]}) for srv in cfg.get('mcpServers',{}).values() if 'args' in srv]; \
    [srv.update({'command':'python3'}) for srv in cfg.get('mcpServers',{}).values() if 'command' in srv and '/Users/edduran/' in srv['command']]; \
    [srv['env'].update({k:v.replace('/Users/edduran','/root')}) for srv in cfg.get('mcpServers',{}).values() if 'env' in srv for k,v in srv['env'].items() if isinstance(v,str) and '/Users/edduran/' in v]; \
    f=open('.mcp.json','w'); json.dump(cfg,f,indent=2); f.close(); print('MCP paths fixed')"

# Global Claude settings (YOLO mode, skip permissions)
RUN cat > $HOME/.claude/settings.json << 'EOF'
{
  "enabledPlugins": {
    "yolo-mode@yolo-marketplace": true
  },
  "extraKnownMarketplaces": {
    "yolo-marketplace": {
      "source": {
        "source": "git",
        "url": "https://github.com/nbiish/yolo-mode.git"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
EOF

# Shell aliases
RUN echo '\n# Claude Code YOLO\nalias claude="claude --dangerously-skip-permissions"\nalias codelive="claude --dangerously-skip-permissions"' >> $HOME/.bashrc

# Expose ports (API + MCP)
EXPOSE 8000 8001

# Auto-start ClaudeBot (Telegram + Discord + Cron)
CMD ["python3", "/root/Documents/GitHub/ai-realtor/claudebot/main.py"]
